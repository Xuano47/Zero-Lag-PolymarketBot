# [CAUTION] Please remove all comments (lines starting with # and text after #) before use to avoid potential parsing errors.
# [注意] 使用前请删除所有注释（以 # 开头的行及字段后的 # 及之后内容），以免产生不必要的解析错误。

# [CAUTION] Please remove all comments (lines starting with # and text after #) before use to avoid potential parsing errors.
# [注意] 使用前请删除所有注释（以 # 开头的行及字段后的 # 及之后内容），以免产生不必要的解析错误。

# --- Polymarket API Configuration ---
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# --- Wallet Configuration ---
# Your private key (HEX format, without '0x' prefix)
PRIVATE_KEY=your_private_key_here
# Your wallet address (starts with '0x')
WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# Optional: Proxy/Funder address
FUNDER_ADDRESS=0x0000000000000000000000000000000000000000

# Signature Type: 1 for EOA (Standard wallet), 0 for default
SIGNATURE_TYPE=1

# --- Trading Strategy Thresholds ---
MIN_PROFIT_THRESHOLD=0.02          # 2% minimum profit
MAX_POSITION_SIZE=6                # Maximum USDC per leg
SLIPPAGE_PADDING=0.0015            # Price slippage buffer
LIQUIDITY_COEFFICIENT=0.5          # % of orderbook depth to consume
MIN_SHARE_THRESHOLD=5              # Minimum shares to purchase
MIN_LIQUIDITY_USD=5000             # Filter low liquidity markets
MAX_LIQUIDITY_USD=50000000         # Filter hyper-competitive markets
MAX_DAYS_UNTIL_RESOLUTION=1        # Max days until market resolution

# --- Performance & Filters ---
EXCLUDE_CRYPTO_MINUTES=true        # Avoid high-volatility crypto minute markets
NUM_WS_CONNECTIONS=4               # Number of parallel WebSocket streams

# --- Safety & Modes ---
# Set to 'false' to enable REAL TRADING. Use 'true' for simulation mode.
DRY_RUN=true
